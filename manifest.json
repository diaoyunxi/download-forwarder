{
  "manifest_version": 3,
  "name": "Download Forwarder",
  "version": "1.8.0",
  "description": "捕获浏览器下载请求并转发到本地下载管理器（wget/curl/IDM/NDM/Gopeed/ffmpeg），支持 Cookie 转发、自定义请求头、代理、URL 规则、右键菜单、快捷键、深色/跟随系统主题、批量下载、文件大小预检、链接嗅探、自动分类、历史重试与筛选、M3U8/HLS 流媒体下载、重复下载提醒",
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "contextMenus",
    "activeTab",
    "alarms",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:18735/*",
    "http://localhost:18735/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-interception": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "切换下载拦截开关"
    },
    "forward-current-page": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "将当前页面链接转发到下载管理器"
    },
    "sniff-links": {
      "description": "嗅探当前页面的可下载链接"
    }
  }
}
